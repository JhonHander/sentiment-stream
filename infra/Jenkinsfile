// =============================================================================
// Jenkinsfile — Declarative Pipeline for Sentiment Stream
// =============================================================================
// Stages: Checkout → Build → Unit Tests → Lint → Integration Tests → Deploy
// Quality gates: tests and lint MUST pass before deployment proceeds.
// =============================================================================

pipeline {
    agent any

    options {
        skipStagesAfterUnstable()
        timeout(time: 30, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timestamps()
    }

    environment {
        COMPOSE_PROJECT_NAME = "sentiment-stream-${BUILD_NUMBER}"
        COMPOSE_FILE_INFRA   = "infra/docker-compose.yml"
        COMPOSE_FILE_TEST    = "infra/docker-compose.test.yml"
    }

    stages {
        // =========================================================================
        // 1. CHECKOUT — Clone repo and log commit info
        // =========================================================================
        stage('Checkout') {
            steps {
                checkout scm
                sh '''
                    echo "=========================================="
                    echo "Branch:  $(git rev-parse --abbrev-ref HEAD)"
                    echo "Commit:  $(git rev-parse --short HEAD)"
                    echo "Author:  $(git log -1 --format='%an')"
                    echo "Message: $(git log -1 --format='%s')"
                    echo "=========================================="
                '''
            }
        }

        // =========================================================================
        // 2. BUILD — Build all Docker images
        // =========================================================================
        stage('Build') {
            steps {
                sh 'docker compose -f "${COMPOSE_FILE_INFRA}" build --no-cache'
            }
        }

        // =========================================================================
        // 3. UNIT TESTS — Run pytest with mocked dependencies (fast, no infra needed)
        // =========================================================================
        stage('Unit Tests') {
            steps {
                script {
                    // Run unit tests inside the API container (no external deps needed)
                    sh '''
                        docker compose -f "${COMPOSE_FILE_TEST}" run --rm api-test \
                            sh -c "pip install pytest pytest-asyncio httpx --quiet && \
                                   pytest tests/test_api/ -v --tb=short --junitxml=test-results.xml"
                    '''
                }
            }
            post {
                always {
                    // Collect test results if available
                    junit allowEmptyResults: true, testResults: '**/test-results.xml'
                }
            }
        }

        // =========================================================================
        // 4. LINT — Code quality checks (flake8 + black)
        // =========================================================================
        stage('Lint') {
            steps {
                script {
                    // Install linters and run checks — NO || true, failures are real
                    sh '''
                        docker compose -f "${COMPOSE_FILE_TEST}" run --rm api-test \
                            sh -c "pip install flake8 black --quiet && \
                                   echo '--- flake8 ---' && \
                                   flake8 api/ tests/ --max-line-length=120 --exclude=__pycache__,.venv && \
                                   echo '--- black --check ---' && \
                                   black --check api/ tests/"
                    '''
                }
            }
        }

        // =========================================================================
        // 5. INTEGRATION TESTS — Full stack with MongoDB
        // =========================================================================
        stage('Integration Tests') {
            steps {
                script {
                    // Start test infrastructure
                    sh 'docker compose -f "${COMPOSE_FILE_TEST}" up -d'

                    // Wait for MongoDB to be healthy
                    sh '''
                        echo "Waiting for MongoDB to be healthy..."
                        timeout 60 bash -c 'until docker compose -f "${COMPOSE_FILE_TEST}" exec -T mongodb-test mongosh --quiet --eval "db.runCommand({ping:1}).ok" >/dev/null 2>&1; do sleep 2; done'
                        echo "MongoDB is healthy."
                    '''

                    // Run integration test script
                    sh 'bash tests/integration/test_docker_compose.sh'
                }
            }
            post {
                always {
                    sh 'docker compose -f "${COMPOSE_FILE_TEST}" down -v --remove-orphans || true'
                }
            }
        }

        // =========================================================================
        // 6. DEPLOY — Bring up the full production stack
        // =========================================================================
        stage('Deploy') {
            when {
                branch 'main'
            }
            steps {
                // Stop existing stack gracefully
                sh 'docker compose -f "${COMPOSE_FILE_INFRA}" down --remove-orphans || true'

                // Start fresh
                sh 'docker compose -f "${COMPOSE_FILE_INFRA}" up -d'

                // Wait for API health
                sh '''
                    echo "Waiting for API to be healthy..."
                    timeout 120 bash -c 'until curl -sf http://localhost:8000/health | grep -q "ok"; do sleep 3; done'
                    echo "API is healthy."
                '''

                // Verify dashboard
                sh '''
                    echo "Waiting for Dashboard..."
                    timeout 60 bash -c 'until curl -sf -o /dev/null http://localhost:80/; do sleep 2; done'
                    echo "Dashboard is reachable."
                '''
            }
        }
    }

    post {
        always {
            sh 'docker compose -f "${COMPOSE_FILE_INFRA}" logs --tail=50 || true'
        }
        success {
            echo '''
            ==========================================
            Pipeline SUCCEEDED!
            ==========================================
            All quality gates passed.
            Services are up and healthy.
            ==========================================
            '''
        }
        failure {
            echo '''
            ==========================================
            Pipeline FAILED!
            ==========================================
            Check the stage logs above to identify
            the failing step.
            ==========================================
            '''
        }
        unstable {
            echo 'Pipeline is UNSTABLE — a quality gate failed. Deployment was skipped.'
        }
    }
}
